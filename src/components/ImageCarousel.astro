---
import { Image } from "astro:assets";

interface Props {
	images: ImageMetadata[];
}

const { images } = Astro.props;
---

{
	images && images.length > 0 && (
		<div x-data="{ activeSlide: 0, slides: [] }" x-init={`slides = Array.from({ length: ${images.length} }).map((_, i) => i)`} class="relative w-full overflow-hidden rounded-xl">
			<div class="relative h-64 md:h-96">
				{images.map((img, index) => (
					<div x-show={`activeSlide === ${index}`} x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0 transform scale-95" x-transition:enter-end="opacity-100 transform scale-100" x-transition:leave="transition ease-in duration-300" x-transition:leave-start="opacity-100 transform scale-100" x-transition:leave-end="opacity-0 transform scale-95" class="absolute inset-0">
						<Image src={img} alt={`Carousel image ${index + 1}`} class="h-full w-full object-cover" />
					</div>
				))}
			</div>

			{images.length > 1 && (
				<>
					<button @click="activeSlide = activeSlide === 0 ? slides.length - 1 : activeSlide - 1" class="absolute left-4 top-1/2 -translate-y-1/2 rounded-full bg-black/50 p-2 text-white hover:bg-black/75">
						<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-6 w-6">
							<path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
						</svg>
					</button>
					<button @click="activeSlide = activeSlide === slides.length - 1 ? 0 : activeSlide + 1" class="absolute right-4 top-1/2 -translate-y-1/2 rounded-full bg-black/50 p-2 text-white hover:bg-black/75">
						<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-6 w-6">
							<path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
						</svg>
					</button>
					<div class="absolute bottom-4 left-1/2 flex -translate-x-1/2 space-x-2">
						{images.map((_, index) => (
							<button @click={`activeSlide = ${index}`} :class={`activeSlide === ${index} ? 'bg-white' : 'bg-white/50'`} class="h-2 w-2 rounded-full transition-colors" />
						))}
					</div>
				</>
			)}
		</div>
	)
}
