---
import { Image } from "astro:assets";

interface Props {
	images: ImageMetadata[];
}

const { images } = Astro.props;
---

{
	images && images.length > 0 && (
		<div x-data="{ activeSlide: 0, slides: [], isLightboxOpen: false }" x-init={`slides = Array.from({ length: ${images.length} }).map((_, i) => i)`} class="carousel-container relative w-full">
			<!-- Main Carousel -->
			<div class="relative overflow-hidden rounded-xl bg-gray-100 dark:bg-gray-800">
				<div class="relative h-64 md:h-96">
					{images.map((img, index) => (
						<div
							x-show={`activeSlide === ${index}`}
							x-transition:enter="transition ease-out duration-300"
							x-transition:enter-start="opacity-0 transform scale-95"
							x-transition:enter-end="opacity-100 transform scale-100"
							x-transition:leave="transition ease-in duration-300"
							x-transition:leave-start="opacity-100 transform scale-100"
							x-transition:leave-end="opacity-0 transform scale-95"
							class="absolute inset-0 cursor-zoom-in"
							@click="isLightboxOpen = true">
							<Image src={img} alt={`Carousel image ${index + 1}`} class="h-full w-full object-contain" />
						</div>
					))}
				</div>

				{images.length > 1 && (
					<>
						<button
							@click.stop="activeSlide = activeSlide === 0 ? slides.length - 1 : activeSlide - 1"
							class="absolute left-4 top-1/2 z-10 -translate-y-1/2 rounded-full bg-black/50 p-2 text-white transition-colors hover:bg-black/75">
							<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-6 w-6">
								<path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
							</svg>
						</button>
						<button
							@click.stop="activeSlide = activeSlide === slides.length - 1 ? 0 : activeSlide + 1"
							class="absolute right-4 top-1/2 z-10 -translate-y-1/2 rounded-full bg-black/50 p-2 text-white transition-colors hover:bg-black/75">
							<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-6 w-6">
								<path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
							</svg>
						</button>
						<div class="absolute bottom-4 left-1/2 z-10 flex -translate-x-1/2 space-x-2">
							{images.map((_, index) => (
								<button
									@click.stop={`activeSlide = ${index}`}
									:class={`activeSlide === ${index} ? 'bg-white' : 'bg-white/50'`}
									class="h-2 w-2 rounded-full transition-colors"
									aria-label={`Go to slide ${index + 1}`}
								/>
							))}
						</div>
					</>
				)}
			</div>

			<!-- Lightbox -->
			<template x-teleport="body">
				<div
					x-show="isLightboxOpen"
					x-transition:enter="transition ease-out duration-300"
					x-transition:enter-start="opacity-0"
					x-transition:enter-end="opacity-100"
					x-transition:leave="transition ease-in duration-200"
					x-transition:leave-start="opacity-100"
					x-transition:leave-end="opacity-0"
					class="fixed inset-0 z-[100] flex items-center justify-center bg-black/90 p-4 md:p-10"
					@keydown.escape.window="isLightboxOpen = false"
					@keydown.left.window="activeSlide = activeSlide === 0 ? slides.length - 1 : activeSlide - 1"
					@keydown.right.window="activeSlide = activeSlide === slides.length - 1 ? 0 : activeSlide + 1"
					style="display: none;">
					<!-- Close Button -->
					<button @click="isLightboxOpen = false" class="absolute right-6 top-6 z-[110] text-white transition-colors hover:text-gray-300">
						<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="h-8 w-8">
							<path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
						</svg>
					</button>

					<!-- Lightbox Image Container -->
					<div class="relative flex h-full w-full items-center justify-center" @click.self="isLightboxOpen = false">
						{images.map((img, index) => (
							<div
								x-show={`activeSlide === ${index}`}
								x-transition:enter="transition ease-out duration-300"
								x-transition:enter-start="opacity-0 scale-90"
								x-transition:enter-end="opacity-100 scale-100"
								class="flex max-h-full max-w-full items-center justify-center">
								<Image src={img} alt={`Carousel image ${index + 1} enlarged`} class="max-h-[85vh] max-w-full object-contain" />
							</div>
						))}

						{images.length > 1 && (
							<>
								<!-- Lightbox Nav -->
								<button
									@click="activeSlide = activeSlide === 0 ? slides.length - 1 : activeSlide - 1"
									aria-label="Previous slide"
									class="absolute left-0 top-1/2 -translate-y-1/2 rounded-full bg-white/10 p-3 text-white transition-colors hover:bg-white/20">
									<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="h-8 w-8">
										<path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
									</svg>
								</button>
								<button
									@click="activeSlide = activeSlide === slides.length - 1 ? 0 : activeSlide + 1"
									aria-label="Next slide"
									class="absolute right-0 top-1/2 -translate-y-1/2 rounded-full bg-white/10 p-3 text-white transition-colors hover:bg-white/20">
									<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="h-8 w-8">
										<path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
									</svg>
								</button>

								<!-- Counter -->
								<div class="absolute bottom-0 left-1/2 -translate-x-1/2 rounded-full bg-black/50 px-3 py-1 text-sm text-white">
									<span x-text="activeSlide + 1" /> / <span>{images.length}</span>
								</div>
							</>
						)}
					</div>
				</div>
			</template>
		</div>
	)
}
// Dummy change to trigger update
