---
interface Props {
	link?: string;
}

const { link } = Astro.props;
---

<div class="audio-player">
	{
		link && (
			<div class="rounded-xl border border-blue-200/20 bg-white/5 p-4">
				<audio controls class="w-full">
					<source src={link} type="audio/mpeg" />
					Your browser does not support the audio element.
				</audio>
				<p class="mt-2 text-sm text-gray-400">
					Source: <a href={link} target="_blank" rel="noopener noreferrer" class="hover:underline">{link}</a>
				</p>
			</div>
		)
	}
</div>
