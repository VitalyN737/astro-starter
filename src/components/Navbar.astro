---
import LanguageSelector from "@components/LanguageSelector.astro";
import HeaderLink from "@components/Link.astro";
import { PAGES, SITE_TITLE } from "@src/consts";
import { tFn } from "@utils/t";

const t = tFn(Astro.url);
---

<header class="sticky top-0 z-30 border-b border-white/10 bg-black/50 backdrop-blur-xl">
	<div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4">
		<a href="/" class="text-sm font-semibold tracking-[0.2em] text-blue-200">{SITE_TITLE}</a>
		<nav class="hidden flex-wrap items-center gap-4 md:flex">
			{PAGES.map((item) => <HeaderLink href={item.href} class="nav-link">{t(item.key)}</HeaderLink>)}
		</nav>
		<LanguageSelector />
	</div>
	<nav class="glass-panel mx-4 mb-4 grid grid-cols-2 gap-2 p-3 md:hidden">
		{PAGES.map((item) => <HeaderLink href={item.href} class="nav-link text-sm">{t(item.key)}</HeaderLink>)}
	</nav>
</header>
