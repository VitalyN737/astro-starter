---
import Layout from "@layouts/Layout.astro";
import Container from "@src/components/Container.astro";
import { getSiteContent } from "@src/data/siteContent";
import { tFn } from "@utils/t";
const c = getSiteContent(Astro.url);
const t = tFn(Astro.url);
---
<Layout title={t("media")}>
	<Container class="pt-12"><section class="glass-panel p-8"><h1 class="text-4xl">{t("media")}</h1><ul class="mt-6 list-disc space-y-2 pl-6">{c.media.map((m) => <li>{m}</li>)}</ul></section></Container>
</Layout>
