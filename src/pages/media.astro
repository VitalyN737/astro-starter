---
import Layout from "@layouts/Layout.astro";
import Container from "@src/components/Container.astro";
import { DEFAULT_LOCALE } from "@src/consts";
import { getCollection, getEntry } from "astro:content";
import { getLocale } from "astro-i18n-aut";

const locale = getLocale(Astro.url) ?? DEFAULT_LOCALE;
const page = await getEntry({ collection: "pages", slug: `${locale}/media` });
const { Content: PageContent } = await page!.render();
const entries = await getCollection("media", (e) => e.slug.startsWith(`${locale}/`));
const items = await Promise.all(entries.map(async (e) => ({ ...e, Content: (await e.render()).Content })));
---
<Layout title={page?.data.title}><Container class="pt-12"><section class="glass-panel p-8"><h1 class="text-4xl">{page?.data.title}</h1><div class="prose prose-invert mt-4"><PageContent /></div><div class="mt-6 space-y-5">{items.map((m)=><article class="rounded-xl border border-blue-200/20 p-5"><h2 class="text-xl">{m.data.title}</h2>{m.data.link && <p><a href={m.data.link} target="_blank" rel="noreferrer">{m.data.link}</a></p>}<div class="prose prose-invert mt-2"><m.Content /></div></article>)}</div></section></Container></Layout>
