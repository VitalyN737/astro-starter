---
import Layout from "@layouts/Layout.astro";
import Container from "@src/components/Container.astro";
import { getSiteContent } from "@src/data/siteContent";
import { tFn } from "@utils/t";
const c = getSiteContent(Astro.url);
const t = tFn(Astro.url);
---
<Layout title={t("schedule")}>
	<Container class="pt-12">
		<section class="glass-panel p-8">
			<h1 class="text-4xl">{t("schedule")}</h1>
			<div class="mt-6 space-y-4">
				{c.schedule.map((s) => <div class="rounded-xl border border-blue-200/20 p-4"><p class="font-semibold">{s.date} — {s.city}</p><p>{s.venue}</p><p class="text-slate-300">{s.work}</p></div>)}
			</div>
		</section>
	</Container>
</Layout>
