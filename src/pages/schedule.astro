---
import Layout from "@layouts/Layout.astro";
import Container from "@src/components/Container.astro";
import { DEFAULT_LOCALE } from "@src/consts";
import { getCollection, getEntry } from "astro:content";
import { getLocale } from "astro-i18n-aut";

const locale = getLocale(Astro.url) ?? DEFAULT_LOCALE;
const page = await getEntry({ collection: "pages", slug: `${locale}/schedule` });
const { Content: PageContent } = await page!.render();
const entries = (await getCollection("schedule", (e) => e.slug.startsWith(`${locale}/`))).sort((a,b)=>a.data.date.valueOf()-b.data.date.valueOf());
const items = await Promise.all(entries.map(async (e) => ({ ...e, Content: (await e.render()).Content })));
---
<Layout title={page?.data.title}>
	<Container class="pt-12"><section class="glass-panel p-8"><h1 class="text-4xl">{page?.data.title}</h1><div class="prose prose-invert mt-4"><PageContent /></div><div class="mt-6 space-y-4">{items.map((s)=><article class="rounded-xl border border-blue-200/20 p-4"><p class="font-semibold">{s.data.date.toISOString().slice(0,10)} — {s.data.city}</p><p>{s.data.venue}</p><div class="prose prose-invert mt-2"><s.Content /></div></article>)}</div></section></Container>
</Layout>
