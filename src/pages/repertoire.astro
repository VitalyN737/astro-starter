---
import Layout from "@layouts/Layout.astro";
import Container from "@src/components/Container.astro";
import { getSiteContent } from "@src/data/siteContent";
import { tFn } from "@utils/t";
const c = getSiteContent(Astro.url);
const t = tFn(Astro.url);
---
<Layout title={t("repertoire")}>
	<Container class="pt-12"><section class="glass-panel p-8"><h1 class="text-4xl">{t("repertoire")}</h1><ul class="mt-6 grid grid-cols-2 gap-3 md:grid-cols-3">{c.repertoire.map((r) => <li class="rounded-lg border border-blue-200/20 p-4">{r}</li>)}</ul></section></Container>
</Layout>
