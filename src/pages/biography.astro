---
import Layout from "@layouts/Layout.astro";
import Container from "@src/components/Container.astro";
import { getSiteContent } from "@src/data/siteContent";
import { tFn } from "@utils/t";
const c = getSiteContent(Astro.url);
const t = tFn(Astro.url);
---
<Layout title={t("biography")}>
	<Container class="pt-12"><section class="glass-panel p-8"><h1 class="text-4xl">{t("biography")}</h1><p class="mt-6 text-lg leading-8 text-slate-200">{c.biography}</p></section></Container>
</Layout>
