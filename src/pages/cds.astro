---
import Layout from "@layouts/Layout.astro";
import Container from "@src/components/Container.astro";
import { getSiteContent } from "@src/data/siteContent";
import { tFn } from "@utils/t";
const c = getSiteContent(Astro.url);
const t = tFn(Astro.url);
---
<Layout title={t("cds")}>
	<Container class="pt-12"><section class="glass-panel p-8"><h1 class="text-4xl">{t("cds")}</h1><div class="mt-6 grid gap-4 md:grid-cols-3">{c.cds.map((cd) => <article class="rounded-xl border border-blue-200/20 p-5"><h2 class="text-xl">{cd}</h2><p class="mt-2 text-slate-300">Studio recording</p></article>)}</div></section></Container>
</Layout>
