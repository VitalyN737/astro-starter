---
import Layout from "@layouts/Layout.astro";
import Container from "@src/components/Container.astro";
import { DEFAULT_LOCALE } from "@src/consts";
import { getCollection, getEntry } from "astro:content";
import { getLocale } from "astro-i18n-aut";

const locale = getLocale(Astro.url) ?? DEFAULT_LOCALE;
const page = await getEntry({ collection: "pages", slug: `${locale}/cds` });
const { Content: PageContent } = await page!.render();
const entries = await getCollection("cds", (e) => e.slug.startsWith(`${locale}/`));
const items = await Promise.all(entries.map(async (e) => ({ ...e, Content: (await e.render()).Content })));
---
<Layout title={page?.data.title}><Container class="pt-12"><section class="glass-panel p-8"><h1 class="text-4xl">{page?.data.title}</h1><div class="prose prose-invert mt-4"><PageContent /></div><div class="mt-6 grid gap-4 md:grid-cols-2">{items.map((cd)=><article class="rounded-xl border border-blue-200/20 p-5"><h2 class="text-xl">{cd.data.title}</h2><p class="text-slate-400">{cd.data.year} {cd.data.label ? `· ${cd.data.label}` : ""}</p><div class="prose prose-invert mt-2"><cd.Content /></div></article>)}</div></section></Container></Layout>
